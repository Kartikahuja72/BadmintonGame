<h2>Edit Player</h2>

<p id="playerTitle"></p>

<form id="editPlayerForm">
  <div class="form-group">
    <label>Player Name</label>
    <input type="text" id="name" placeholder="Player Name" required autofocus>
  </div>

  <div class="form-group">
    <label>Phone</label>
    <input type="text" id="phone" placeholder="Enter 10-digit phone" required>
  </div>

  <button type="submit">Update Player</button>
</form>

<p id="error"></p>

<style>
  body {
    font-family: Arial, sans-serif;
  }

  h2 {
    margin-bottom: 10px;
  }

  .form-group {
    margin-bottom: 12px;
  }

  label {
    display: block;
    margin-bottom: 4px;
  }

  input {
    padding: 6px;
    width: 250px;
  }

  button {
    margin-top: 10px;
    padding: 6px 12px;
    background: #2c3e50;
    color: white;
    border: none;
    cursor: pointer;
  }

  button:hover {
    background: #34495e;
  }

  #playerTitle {
    font-weight: bold;
    margin-bottom: 10px;
  }

  #error {
    color: red;
    margin-top: 10px;
  }
</style>